{"id": "1220848575966089409", "channel_id": "1210594811363594350", "type": 0, "author_id": "1168864875943055370", "author_name": "silverstream_s", "author_bot": false, "content": "至此，缺失的利莫里亚文字只剩下：\nB，J，K，Q，X，Y，Z\n\n以上。", "timestamp": "2024-03-22T21:36:22.780000+00:00", "edited_timestamp": "2024-03-22T21:44:13.045000+00:00", "pinned": false, "mentions": [], "reactions": [{"emoji": "🍟", "emoji_id": null, "count": 6}], "attachments": [], "embeds": [], "reply_to": null, "has_thread": false, "thread_id": "1210594811363594350", "flags": 0, "thread_title": "关于游戏自造语：古代利莫里亚语", "forum_channel_id": "1181146739198140487"}
