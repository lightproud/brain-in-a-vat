{"id": "1340857070630735993", "channel_id": "1329362854721224704", "type": 0, "author_id": "191643200950239232", "author_name": "jadlithon", "author_bot": false, "content": "Getting an Embryo every 2 turns at worst is absolutely huge for both generating ults and generating devours.", "timestamp": "2025-02-17T01:27:17.558000+00:00", "edited_timestamp": null, "pinned": false, "mentions": [], "reactions": [], "attachments": [], "embeds": [], "reply_to": null, "has_thread": false, "thread_id": "1329362854721224704", "flags": 0, "thread_title": "Tier list as of 2.0", "forum_channel_id": "1304022827824844842"}
{"id": "1340857133435982024", "channel_id": "1329362854721224704", "type": 0, "author_id": "191643200950239232", "author_name": "jadlithon", "author_bot": false, "content": "And means you pretty much always have one to turn into a Holy Child.", "timestamp": "2025-02-17T01:27:32.532000+00:00", "edited_timestamp": null, "pinned": false, "mentions": [], "reactions": [], "attachments": [], "embeds": [], "reply_to": null, "has_thread": false, "thread_id": "1329362854721224704", "flags": 0, "thread_title": "Tier list as of 2.0", "forum_channel_id": "1304022827824844842"}
