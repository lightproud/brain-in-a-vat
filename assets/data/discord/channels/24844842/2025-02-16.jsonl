{"id": "1340802224409940039", "channel_id": "1329362854721224704", "type": 19, "author_id": "191643200950239232", "author_name": "jadlithon", "author_bot": false, "content": "Caro in general's base Embryo gain went from 20 -> 30%\nWhich means instead of Thais E3 making the gain go from 20-40 up to 30-60, it's now 30-60 up to 45-90% passive Embryo Gain.", "timestamp": "2025-02-16T21:49:21.200000+00:00", "edited_timestamp": null, "pinned": false, "mentions": ["111186237892653056"], "reactions": [], "attachments": [], "embeds": [], "reply_to": "1340799651661480046", "has_thread": false, "thread_id": "1329362854721224704", "flags": 0, "thread_title": "Tier list as of 2.0", "forum_channel_id": "1304022827824844842"}
