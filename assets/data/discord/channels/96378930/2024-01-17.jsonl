{"id": "1197104385042432100", "channel_id": "1196941586446176297", "type": 19, "author_id": "1181971546496061540", "author_name": "luguang12345", "author_bot": false, "content": "我的确收到大量来自小红书玩家的反馈，萝坦无3启，无光6被卡关的问题。", "timestamp": "2024-01-17T09:05:26.518000+00:00", "edited_timestamp": null, "pinned": false, "mentions": ["1188482378948165682"], "reactions": [], "attachments": [], "embeds": [], "reply_to": "1197075040710184981", "has_thread": false, "thread_id": "1196941586446176297", "flags": 0, "thread_title": "角色梯度总榜与分榜（超认真项与整活项）", "forum_channel_id": "1174179624096378930", "thread_tags": ["1174179734373019748", "1196356931191832677", "1174179755759763526", "1174179680056791130", "1174179700470460447"]}
