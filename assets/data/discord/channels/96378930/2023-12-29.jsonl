{"id": "1190199503702204507", "channel_id": "1190199503702204507", "type": 0, "author_id": "203498180946558976", "author_name": "eceniht", "author_bot": false, "content": "懶人包\n\n紅悸 3暴傷2強效 \n+隕日   (3星強無敵 低星應該賭旋轉毒暴 傷害更高點 )\n+臨界或苦咒   哪個+的多用哪個就行 甚至你有+12死亡的剖析或致摯友也能用 畢業拿臨界", "timestamp": "2023-12-29T07:47:54.520000+00:00", "edited_timestamp": "2023-12-29T07:57:02.371000+00:00", "pinned": false, "mentions": [], "reactions": [{"emoji": "🍟", "emoji_id": null, "count": 2}, {"emoji": "👍", "emoji_id": null, "count": 3}], "attachments": [{"id": "1190199503928705025", "filename": "cee7810f4d2cb3c1.xlsx", "content_type": "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet", "size": 17147, "url": "https://cdn.discordapp.com/attachments/1190199503702204507/1190199503928705025/cee7810f4d2cb3c1.xlsx?ex=69cc24ea&is=69cad36a&hm=1da6d8e5abd14fe968d320d4a7bce32ddaa203f63c484d1e612972a5cc1590c2&"}], "embeds": [], "reply_to": null, "has_thread": false, "thread_id": "1190199503702204507", "flags": 0, "thread_title": "莉茲傷害測算", "forum_channel_id": "1174179624096378930", "thread_tags": ["1174179755759763526"]}
