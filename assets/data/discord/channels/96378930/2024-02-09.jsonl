{"id": "1205363997142945852", "channel_id": "1202785630715781212", "type": 19, "author_id": "1189893777427537980", "author_name": "mihutu.", "author_bot": false, "content": "这样，确实鲨鱼不是很泛用，今天刚刚把鲨鱼回溯了，如果有弥补就好了", "timestamp": "2024-02-09T04:06:11.499000+00:00", "edited_timestamp": null, "pinned": false, "mentions": ["1112189464140324947"], "reactions": [], "attachments": [], "embeds": [], "reply_to": "1204948777874489425", "has_thread": false, "thread_id": "1202785630715781212", "flags": 0, "thread_title": "2.1版本后的深海思路与探索", "forum_channel_id": "1174179624096378930", "thread_tags": ["1211882178007408651", "1174179716706619494"]}
