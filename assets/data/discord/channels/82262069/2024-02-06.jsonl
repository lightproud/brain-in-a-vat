{"id": "1204375367863767161", "channel_id": "1204366577877782528", "type": 0, "author_id": "968857106985910302", "author_name": "enosred", "author_bot": false, "content": "而且海之梦还需要3个回合才能触发一次。", "timestamp": "2024-02-06T10:37:43.911000+00:00", "edited_timestamp": null, "pinned": false, "mentions": [], "reactions": [], "attachments": [], "embeds": [], "reply_to": null, "has_thread": false, "thread_id": "1204366577877782528", "flags": 0, "thread_title": "✅V1.2下篇「遊戲性」的調整計劃", "forum_channel_id": "1184003940082262069"}
