{"id": "1441975803679215757", "channel_id": "1439904688622403638", "type": 19, "author_id": "1379709964242780241", "author_name": "txt101225.", "author_bot": false, "content": "不太会玩医生，现在配队是鼠鼠、诗人、环娜、融朵", "timestamp": "2025-11-23T02:17:02.212000+00:00", "edited_timestamp": null, "pinned": false, "mentions": ["624926363778023434"], "reactions": [], "attachments": [], "embeds": [], "reply_to": "1441831152150118570", "has_thread": false, "thread_id": "1439904688622403638", "flags": 0, "thread_title": "求配队", "forum_channel_id": "1356200054276493444"}
