{"id": "1415216195325530123", "channel_id": "1414676585772093622", "type": 0, "author_id": "452516689225973761", "author_name": "thpdom", "author_bot": false, "content": "Talking about textbooks and fonts. I would generally prefer the font to be smaller on pc, the font is big to suit mobile users. But for pc users it can be smaller/fit more of the line.", "timestamp": "2025-09-10T06:03:54.411000+00:00", "edited_timestamp": null, "pinned": false, "mentions": [], "reactions": [], "attachments": [], "embeds": [], "reply_to": null, "has_thread": false, "thread_id": "1414676585772093622", "flags": 0, "thread_title": "✅「Answered」Dialogue Scroll Was a Mistake", "forum_channel_id": "1180845276823564288", "thread_tags": ["1361168939622727801"]}
