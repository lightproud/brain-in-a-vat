{"id": "1424652439906418761", "channel_id": "1421726131777966130", "type": 19, "author_id": "244028747999608832", "author_name": "vxvendetta", "author_bot": false, "content": "the pity is 60, if you find an off banner the next will be the on banner wheel or unit at random", "timestamp": "2025-10-06T07:00:10.436000+00:00", "edited_timestamp": null, "pinned": false, "mentions": ["452516689225973761"], "reactions": [], "attachments": [], "embeds": [], "reply_to": "1424645018282492025", "has_thread": false, "thread_id": "1421726131777966130", "flags": 0, "thread_title": "Timeless Banner Question", "forum_channel_id": "1180845276823564288", "thread_tags": ["1361169005435420785"]}
