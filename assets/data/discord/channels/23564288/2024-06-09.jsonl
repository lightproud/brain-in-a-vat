{"id": "1249351165297033267", "channel_id": "1247963491512487936", "type": 0, "author_id": "781400757924397086", "author_name": "lin7434", "author_bot": false, "content": "神父無腦程度太高了", "timestamp": "2024-06-09T13:15:29.629000+00:00", "edited_timestamp": null, "pinned": false, "mentions": [], "reactions": [], "attachments": [], "embeds": [], "reply_to": null, "has_thread": false, "thread_id": "1247963491512487936", "flags": 0, "thread_title": "校猫出来说话", "forum_channel_id": "1180845276823564288", "thread_tags": ["1181168158678204497"]}
