{"id": "1280509721039601698", "channel_id": "1280443812392472606", "type": 19, "author_id": "676337286769672192", "author_name": "hailananxie7110", "author_bot": false, "content": "主要是沒有特色吧...對標雷婭，一樣三圍不行，但雷婭有大奶阿🤣", "timestamp": "2024-09-03T12:48:28.216000+00:00", "edited_timestamp": null, "pinned": false, "mentions": ["1050476549985534053"], "reactions": [], "attachments": [], "embeds": [], "reply_to": "1280506277813817355", "has_thread": false, "thread_id": "1280443812392472606", "flags": 0, "thread_title": "加強朵兒", "forum_channel_id": "1180845276823564288", "thread_tags": ["1181168158678204497"]}
