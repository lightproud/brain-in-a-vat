# Twitter/X API (可选 - 不配置则跳过Twitter数据源)
TWITTER_BEARER_TOKEN=

# NGA 论坛版块ID (可选 - 忘却前夜的版块ID)
NGA_FORUM_ID=

# TapTap 应用ID (可选)
TAPTAP_APP_ID=

# YouTube Data API v3 (可选 - 不配置则跳过或使用RSS回退)
YOUTUBE_API_KEY=
# YouTube 官方频道ID (可选 - 用于RSS回退抓取)
YOUTUBE_CHANNEL_ID=

# Discord Bot API (可选 - 抓取指定频道消息)
DISCORD_BOT_TOKEN=
# 逗号分隔的频道ID列表
DISCORD_CHANNEL_IDS=

# LLM API 用于生成每日总结 (可选 - 不配置则使用简单提取式总结)
LLM_API_KEY=
LLM_API_URL=https://api.anthropic.com/v1/messages
