{"id": "1478936613689229405", "channel_id": "1478923108122365967", "type": 0, "author_id": "883992032530563082", "author_name": "void_1546.", "author_bot": false, "content": "Mouchette's ATK is 159, and her ATK bonus for attacks is 20%, so her attack damage is 159 multiplied by 20%, which equals 32.", "timestamp": "2026-03-05T02:06:06.017000+00:00", "edited_timestamp": null, "pinned": false, "mentions": [], "reactions": [], "attachments": [{"id": "1478936612078620692", "filename": "IMG_5904.png", "content_type": "image/png", "size": 3954728}, {"id": "1478936613009494170", "filename": "IMG_5905.png", "content_type": "image/png", "size": 3217059}], "embeds": [], "reply_to": null, "has_thread": false, "thread_id": null, "flags": 0}
