# ========== 数据源 API Keys ==========

# --- 无需 API Key (直接可用) ---
# Reddit: 公开 JSON API
# Bilibili: 搜索 API
# Tieba: 百度贴吧 API

# --- 中文平台 ---
# NGA 论坛版块ID
NGA_FORUM_ID=
# TapTap 应用ID
TAPTAP_APP_ID=
# (Weibo/Xiaohongshu/Douyin 使用公开搜索接口，可能需要 Cookie)
# (Zhihu 知乎: 使用公开搜索接口)
# QQ 频道 Bot
QQ_GUILD_ID=
QQ_BOT_TOKEN=
# 巴哈姆特版块编号 (台湾游戏社区)
BAHAMUT_BSN=

# --- 同人创作平台 ---
# Pixiv: 使用公开搜索接口 (可能需要 Cookie)
# Lofter: 使用公开搜索接口

# --- 周边/交易平台 ---
# 闲鱼/淘宝: 使用 H5 搜索接口 (公开)

# --- 全球平台 ---
# Twitter/X API v2 Bearer Token
TWITTER_BEARER_TOKEN=
# YouTube Data API v3 Key
YOUTUBE_API_KEY=
# Discord Bot Token + 频道ID (逗号分隔)
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_IDS=
# Facebook Graph API
FACEBOOK_ACCESS_TOKEN=
FACEBOOK_PAGE_IDS=

# TikTok: 使用公开搜索接口
# Telegram 公开频道/群组 (逗号分隔，如 morimens_official,morimens_chat)
TELEGRAM_CHANNELS=
# Twitch API
TWITCH_CLIENT_ID=
TWITCH_ACCESS_TOKEN=
# Instagram Graph API (需要 Facebook 开发者账号)
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=

# --- 韩国平台 ---
# DCInside Gallery ID (忘却前夜 갤러리)
DC_GALLERY_ID=
# Arca.live 频道名
ARCA_CHANNEL=

# --- 应用商店 ---
# Apple App Store App ID (用于抓评论)
APPSTORE_APP_ID=
# Google Play 包名 (如 com.example.morimens)
GOOGLE_PLAY_PACKAGE=

# ========== AI 总结 ==========

# Anthropic API Key (用于 AI 生成报告摘要，可选)
LLM_API_KEY=
LLM_API_URL=https://api.anthropic.com/v1/messages

# ========== 报告配置 ==========

# 报告语言 (zh / en / ja / ko / all)
REPORT_LANG=all

# 数据回溯时间 (小时)
HOURS_LOOKBACK=24

# ========== 通知推送 (全部可选，未配置的渠道自动跳过) ==========

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
NOTIFY_EMAIL=

# Discord Webhook URL
NOTIFY_DISCORD_WEBHOOK=

# Telegram Bot
NOTIFY_TELEGRAM_BOT_TOKEN=
NOTIFY_TELEGRAM_CHAT_ID=

# Bark (iOS 推送)
NOTIFY_BARK_URL=

# 自定义 Webhook (POST JSON)
NOTIFY_WEBHOOK_URL=
